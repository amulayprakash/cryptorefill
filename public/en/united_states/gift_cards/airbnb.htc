":\"\",\"products\":[{\"product_id\":\"99be18af-4022-48e0-894c-9844d8a96e4c\",\"is_dynamic\":true,\"range\":{\"min\":50,\"max\":500,\"currency\":\"USD\",\"step_size\":1,\"default\":\"500.0\"},\"coin\":\"USDC\",\"payment_method\":\"USDC-MATIC\",\"delivery_type\":\"by_email\",\"points\":\"44\",\"face_value\":{\"currency_code\":\"USD\",\"amount\":{\"type\":\"range\",\"min\":\"50.00\",\"max\":\"500.00\"}}}],\"brand_id\":\"0ce084d1-a783-4128-bd72-be28c5c4dca0\",\"family\":\"Airbnb\",\"additional_categories\":[],\"brand_tags\":[],\"product_type\":\"physical\",\"is_out_of_stock\":false,\"brand\":\"Airbnb\",\"logo_url\":\"https://cdn.cryptorefills.com/logos_v2/airbnb.webp\",\"logo_base_url\":\"https://cdn.cryptorefills.com/logos_v2/airbnb\",\"product_tc\":\"Buy now a Airbnb gift card with Bitcoin and other Crypto. Receive your gift card instantly by email. Important, this product may not work in countries outside of United States, redeeming with a VPN will likely not work. Pay with Bitcoin, Litecoin, Ethereum, USDC, USDT, MIM, EUROC, FRAX, EUROC, BUSD, and DAI on Lightning Network, Avalanche, Polygon, Fantom, Binance Chain, and Arbitrum.\",\"redeem_method\":[\"Online\"],\"rich_description\":{\"markup\":\"html\",\"description\":\"\u003cp\u003eAmazing places to stay and things to do do, all around the world.\u003c/p\u003e\",\"how_to_redeem\":\"\u003cp\u003e* Sign up or log in at \u003ca href=\\\"https://www.airbnb.com/gift/redeem\\\"\u003eairbnb.com/gift/redeem\u003c/a\u003e\u003cbr\u003e* Enter the Card Number and PIN when prompted\u003cbr\u003e* Your credit will be applied to your account\u003c/p\u003e\",\"redeem_geo\":null,\"term_and_conditions\":\"$9a\",\"country_code\":\"US\",\"locale\":\"en\",\"note\":null,\"brand_tagline\":null,\"brand_use_case\":null,\"brand_url\":null,\"brand_alt_names\":null}}}]}],[\"$\",\"div\",null,{\"className\":\"relative mt-5 flex w-auto min-w-0 flex-col space-y-4 px-3 lg:mt-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-col gap-y-1\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-2xl font-semibold\",\"children\":[\"Airbnb\",\" \",\"gift card\"]}],null]}],[\"$\",\"$L9b\",null,{\"productReviews\":[{\"name\":\"Swaq\",\"reviewBody\":\"Perfection.\",\"language\":\"en\",\"reviewRating\":5,\"datePublished\":\"2024-05-31\",\"platform\":\"trustpilot\",\"kinds\":[],\"isoCodes\":[\"IT\"],\"brands\":[\"Airbnb\"],\"translations\":[{\"locale\":\"de\",\"reviewBody\":\"Perfektion.\"},{\"locale\":\"es\",\"reviewBody\":\"Perfección.\"},{\"locale\":\"it\",\"reviewBody\":\"Perfezione.\"},{\"locale\":\"tr\",\"reviewBody\":\"Mükemmellik.\"},{\"locale\":\"fr\",\"reviewBody\":\"Perfection.\"},{\"locale\":\"tl\",\"reviewBody\":\"Kahusayan.\"},{\"locale\":\"vi\",\"reviewBody\":\"Sự hoàn hảo.\"},{\"locale\":\"zh\",\"reviewBody\":\"完美。\"},{\"locale\":\"pt\",\"reviewBody\":\"Perfeição.\"},{\"locale\":\"ar\",\"reviewBody\":\"الكمال.\"},{\"locale\":\"hi\",\"reviewBody\":\"पूर्णता।\"},{\"locale\":\"pl\",\"reviewBody\":\"Perfekcja.\"},{\"locale\":\"id\",\"reviewBody\":\"Kesempurnaan.\"},{\"locale\":\"ja\",\"reviewBody\":\"完璧です。\"},{\"locale\":\"ko\",\"reviewBody\":\"완벽함.\"}],\"_fingerprint\":\"2d5f9d2d73f89a6681217e408941517571b025ecd9aa5a6f1765b411d1a3f2c0\"},{\"name\":\"John\",\"reviewBody\":\"ça marche\",\"language\":\"fr\",\"reviewRating\":5,\"datePublished\":\"2024-01-17\",\"platform\":\"trustpilot\",\"kinds\":[],\"isoCodes\":[\"FR\"],\"brands\":[\"Airbnb\"],\"translations\":[{\"locale\":\"en\",\"reviewBody\":\"It works\"},{\"locale\":\"de\",\"reviewBody\":\"Es funktioniert\"},{\"locale\":\"es\",\"reviewBody\":\"Funciona\"},{\"locale\":\"it\",\"reviewBody\":\"Funziona\"},{\"locale\":\"tr\",\"reviewBody\":\"Çalışıyor\"},{\"locale\":\"tl\",\"reviewBody\":\"Gumagana ito\"},{\"locale\":\"vi\",\"reviewBody\":\"Nó hoạt động\"},{\"locale\":\"zh\",\"reviewBody\":\"它有效\"},{\"locale\":\"pt\",\"reviewBody\":\"Funciona\"},{\"locale\":\"ar\",\"reviewBody\":\"إنه يعمل\"},{\"locale\":\"hi\",\"reviewBody\":\"यह काम करता है\"},{\"locale\":\"pl\",\"reviewBody\":\"Działa\"},{\"locale\":\"id\",\"reviewBody\":\"Ini berfungsi\"},{\"locale\":\"ja\",\"reviewBody\":\"うまくいく\"},{\"locale\":\"ko\",\"reviewBody\":\"작동해요\"}],\"_fingerprint\":\"1531e6ce522dab49ad0f687ef995a8c18147de1eab850ea6f6f5510842fec659\"},{\"name\":\"Marghe\",\"reviewBody\":\"I bought a gift card and everything works perfect. Great customer service. Thank you guys\",\"language\":\"en\",\"reviewRating\":5,\"datePublished\":\"2021-10-19\",\"platform\":\"trustpilot\",\"url\":\"https://trustpilot.com/reviews/616ebff575069a4da4899ec2\",\"kinds\":[],\"isoCodes\":[],\"brands\":[\"Airbnb\"],\"translations\":[{\"locale\":\"de\",\"reviewBody\":\"Ich habe eine Geschenkkarte gekauft und alles funktioniert perfekt. Toller Kundenservice. Vielen Dank, Leute.\"},{\"locale\":\"es\",\"reviewBody\":\"Compré una tarjeta de regalo y todo funciona perfecto. Excelente servicio al cliente. Gracias, chicos.\"},{\"locale\":\"it\",\"reviewBody\":\"Ho comprato una carta regalo e tutto funziona perfettamente. Ottimo servizio clienti. Grazie ragazzi.\"},{\"locale\":\"tr\",\"reviewBody\":\"Bir hediye kartı aldım ve her şey mükemmel çalışıyor. Harika müşteri hizmetleri. Teşekkürler arkadaşlar.\"},{\"locale\":\"fr\",\"reviewBody\":\"J'ai acheté une carte cadeau et tout fonctionne parfaitement. Excellent service client. Merci à vous.\"},{\"locale\":\"tl\",\"reviewBody\":\"Bumili ako ng gift card at lahat ay gumagana nang perpekto. Mahusay na serbisyo sa customer. Salamat mga guys.\"},{\"locale\":\"vi\",\"reviewBody\":\"Tôi đã mua thẻ quà tặng và mọi thứ hoạt động hoàn hảo. Dịch vụ khách hàng tuyệt vời. Cảm ơn các bạn.\"},{\"locale\":\"zh\",\"reviewBody\":\"我买了一张礼品卡，一切运行完美。客户服务很棒。谢谢你们。\"},{\"locale\":\"pt\",\"reviewBody\":\"Comprei um cartão presente e tudo funciona perfeitamente. Ótimo atendimento ao cliente. Obrigado, pessoal.\"},{\"locale\":\"ar\",\"reviewBody\":\"اشتريت بطاقة هدايا وكل شيء يعمل بشكل مثالي. خدمة عملاء رائعة. شكراً لكم يا شباب.\"},{\"locale\":\"hi\",\"reviewBody\":\"मैंने एक गिफ्ट कार्ड खरीदा और सब कुछ बिल्कुल सही काम कर रहा है। शानदार ग्राहक सेवा। धन्यवाद दोस्तों।\"},{\"locale\":\"pl\",\"reviewBody\":\"Kupiłem kartę podarunkową i wszystko działa perfekcyjnie. Świetna obsługa klienta. Dziękuję wam.\"},{\"locale\":\"id\",\"reviewBody\":\"Saya membeli kartu hadiah dan semuanya berjalan sempurna. Layanan pelanggan yang hebat. Terima kasih teman-teman.\"},{\"locale\":\"ja\",\"reviewBody\":\"ギフトカードを購入しましたが、すべて完璧に動作しています。素晴らしいカスタマーサービスです。ありがとう皆さん。\"},{\"locale\":\"ko\",\"reviewBody\":\"기프트 카드를 샀는데 모든 것이 완벽하게 작동합니다. 훌륭한 고객 서비스입니다. 감사합니다 여러분.\"}],\"_fingerprint\":\"7443e6a47d6c1e037a5b1c67c14ec84f13c55513eb9f25d4eb53c33ef9959364\"}]}],\"$L9c\",null,\"$L9d\",\"$L9e\",\"$L9f\",\"$La0\",\"$La1\",\"$La2\",\"$La3\"]}]]}]}]\n"])</script><script>self.__next_f.push([1,"97:[\"$\",\"div\",null,{\"id\":\"reviews\",\"className\":\"mt-7\",\"children\":[\"$\",\"$La4\",null,{\"locale\":\"en\",\"filteredReviews\":\"$96:props:children:props:children:1:props:children:1:props:productReviews\",\"offset\":\"scroll-pl-6xl\",\"classesHeader\":\"max-w-6xl\"}]}]\n98:null\n"])</script><script>self.__next_f.push([1,"a5:I[447533,[\"https://cdn.cryptorefills.com/_next/static/chunks/381hrw29qiq8q.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/1m2b0a3j2jjcm.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/3w0z0n-zl73at.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/23mpn79-5blfz.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/36xsdqeogwaol.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/21za61_xxgaxr.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/0ut1etnuw4t_2.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/2po7bg7qzpghr.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/01-gaapikfq3i.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/1662zfxk-hwkj.js\",\"https://cdn.cryptorefills.com/_next/static/chunks/287o2neounz1t.js\",\"https://cdn.cryptorefills.com/_next/sta