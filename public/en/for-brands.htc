div\",null,{\"className\":\"mx-auto max-w-6xl px-4 sm:px-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-16 max-w-3xl\",\"children\":[\"$\",\"h2\",null,{\"className\":\"flex flex-col text-3xl font-bold tracking-tight sm:text-4xl dark:text-white\",\"children\":[\"One integration\",[\"$\",\"span\",null,{\"className\":\"font-normal text-primary-400 dark:text-primary-200\",\"children\":\"Reach into the exchanges and wallets where hundreds of millions of crypto users already are\"}]]}]}],[\"$\",\"$L36\",null,{}]]}]}]\n34:[\"$\",\"div\",null,{\"id\":\"integration\",\"className\":\"relative scroll-mt-24 bg-linear-to-l from-primary-100 to-white dark:from-gray-950 dark:to-gray-900\",\"children\":[[[\"$\",\"div\",null,{\"className\":\"pointer-events-none absolute inset-0 dark:hidden\",\"style\":{\"background\":\"radial-gradient(ellipse 80% 50% at 0% 0%, color-mix(in srgb, var(--color-primary-200) 40%, transparent), transparent)\"}}],[\"$\",\"div\",null,{\"className\":\"pointer-events-none absolute inset-0 hidden dark:block\",\"style\":{\"background\":\"radial-gradient(ellipse 80% 50% at 0% 0%, color-mix(in srgb, var(--color-gray-950) 70%, transparent), transparent)\"}}]],[\"$\",\"$L37\",null,{\"contactPartnershipsLink\":\"/en/contact-partnerships\"}]]}]\n"])</script><script>self.__next_f.push([1,"35:[\"$\",\"section\",null,{\"className\":\"bg-white py-24 sm:py-32 dark:bg-gray-900\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto w-full max-w-6xl px-4 sm:px-6\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex flex-col justify-between lg:flex-row lg:space-x-5\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-col lg:w-1/3 lg:pr-10\",\"children\":[\"$\",\"h2\",null,{\"className\":\"mb-7 flex flex-col text-3xl font-bold tracking-tight sm:text-4xl dark:text-white\",\"children\":\"Common questions from brands\"}]}],[\"$\",\"div\",null,{\"className\":\"flex w-full flex-col items-center text-gray-600 sm:rounded-2xl lg:w-2/3\",\"children\":[\"$\",\"$L38\",null,{\"faqQuestions\":[{\"subject\":\"for-brands\",\"questions\":[{\"subject\":\"\",\"question\":\"What types of products can I sell on Cryptorefills?\",\"answer\":\"Cryptorefills supports digital products including gift cards, gaming credits, eSIM, mobile top up, travel bookings and subscription services. If you sell a digital or redeemable product, there is likely a place for it on our platform.\"},{\"subject\":\"\",\"question\":\"Do I need to integrate via API to list my products?\",\"answer\":\"No. We offer both API-based integrations for large-scale partners and a managed stock model for mid-size brands that don't have API infrastructure. Our team handles the operational setup.\"},{\"subject\":\"\",\"question\":\"How does Cryptorefills handle settlement and chargebacks?\",\"answer\":\"You see live sales in your portal as they happen, and invoice us on your own schedule. Most brands run monthly. We pay the invoice same-day in EUR, T+1 in USD, GBP, CHF or MXN, faster on stablecoins or BTC. Crypto rails don't reverse, so there are no chargebacks, and consumer-side disputes are ours to handle.\"},{\"subject\":\"\",\"question\":\"How does Cryptorefills distribute products beyond its own website?\",\"answer\":\"Cryptorefills has distribution partnerships with major crypto exchanges and wallets including KuCoin, Bitget, Kraken, World and others. Products listed with us are surfaced across these platforms, extending reach beyond our direct user base, including in regions where card-based distribution is thin.\"},{\"subject\":\"\",\"question\":\"What is B2A and how does it apply to my brand?\",\"answer\":\"B2A (Business to Agent) is a new commercial channel where AI agents autonomously discover and purchase products on behalf of users. Cryptorefills supports MCP APIs and the x402 payment protocol, making listed products natively accessible to AI shopping agents, a rapidly growing segment.\"},{\"subject\":\"\",\"question\":\"What currencies does Cryptorefills accept?\",\"answer\":\"We accept all major stablecoins including USDT and USDC, Bitcoin (including via Lightning Network for instant low-fee payments) and all other leading crypto. We are also the first ecommerce platform to accept stablecoin payments via alternative networks including Avalanche, Solana and Polygon.\"}]}]}]}]]}]}]}]\n"])</script><script>self.__next_f.push([1,"20:[\"$\",\"html\",null,{\"lang\":\"en\",\"dir\":\"ltr\",\"className\":\" \",\"data-theme\":\"light\",\"children\":[[\"$\",\"$L39\",null,{\"children\":[[\"$\",\"$L3a\",null,{\"moduleIds\":[\"8250371854878145849\"]}],[\"$\",\"$L3b\",null,{\"clientPlatform\":\"web\",\"userId\":\"$undefined\"}]]}],null,[[\"$\",\"$L3a\",null,{\"moduleIds\":[\"8814065701768275544\"]}],[\"$\",\"$L3c\",null,{\"availableLanguage\":[\"en\",\"de\",\"es\",\"it\",\"tr\",\"fr\",\"vi\",\"zh\",\"pt\",\"hi\",\"pl\",\"id\",\"ja\",\"ko\"]}]],[\"$\",\"meta\",null,{\"name\":\"theme-color\",\"content\":\"#01075F\"}],[\"$\",\"meta\",null,{\"name\":\"apple-itunes-app\",\"content\":\"app-id=1534284069\"}],[\"$\",\"body\",null,{\"className\":\"bg-gray-50 dark:bg-gray-900 dark:text-gray-200\",\"children\":\"$L3d\"}]]}]\n2c:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n"])</script><script>self.__next_f.push([1,"3d:[\"$\",\"$L3e\",null,{\"formats\":\"$undefined\",\"locale\":\"en\",\"messages\":{\"LanguageByIsoCode\":{\"en\":\"English\",\"es\":\"Spanish\",\"de\":\"German\",\"it\":\"Italian\",\"tr\":\"Turkish\",\"fr\":\"French\",\"tl\":\"Filipino\",\"vi\":\"Vietnamese\",\"zh\":\"Chinese\",\"pt\":\"Portuguese\",\"ar\":\"Arabic\",\"hi\":\"Hindi\",\"pl\":\"Polish\",\"id\":\"Indonesian\",\"ja\":\"Japanese\",\"ko\":\"Korean\"},\"Routes\":{\"about\":\"about\",\"account\":\"account\",\"account/orders\":\"account/orders\",\"account/admin\":\"account/admin\",\"checkout\":\"checkout\",\"faq\":\"faq\",\"travel\":\"travel\",\"flights/search\":\"flights