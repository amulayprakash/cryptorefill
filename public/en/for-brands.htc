-events-none absolute inset-0 [background-image:radial-gradient(circle,rgba(209,213,219,0.6)_1px,transparent_1px)] dark:[background-image:radial-gradient(circle,rgba(55,65,81,0.5)_1px,transparent_1px)] [background-size:28px_28px]"></div><div class="relative mx-auto w-full max-w-6xl px-4 py-16 sm:px-8 sm:py-20"><div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2"><div><h1 class="text-5xl font-bold tracking-tighter text-gray-900 sm:text-6xl lg:text-7xl dark:text-white" style="opacity:0;transform:translateY(24px)">Your brand, where crypto gets spent</h1><p class="mt-8 text-lg leading-relaxed text-gray-500 dark:text-gray-400" style="opacity:0;transform:translateY(24px)">One integration. Direct access to hundreds of thousands of active buyers across 180+ countries, including markets where card payments don&#x27;t reach.</p><div class="mt-10 flex flex-wrap gap-3" style="opacity:0;transform:translateY(24px)"><a class="w-full rounded-lg bg-primary-900 px-8 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-primary-800 dark:bg-gray-50 dark:text-primary-900 sm:w-auto" href="/en/contact-partnerships">Talk to partnerships</a><a class="w-full rounded-lg border border-gray-300 px-8 py-3.5 text-center text-base font-semibold text-gray-700 transition-colors hover:border-gray-500 hover:text-gray-900 dark:border-white/30 dark:text-white dark:hover:border-white/60 sm:w-auto" href="#integration">See how it works</a></div></div><div style="opacity:0;transform:translateX(32px)"><h2 class="mb-3 flex flex-col text-xl font-semibold text-gray-500 dark:text-gray-300">Settle on your terms. In hours, not weeks.</h2><div class="flex h-112 w-full flex-col rounded-2xl border border-gray-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-gray-900 dark:shadow-none"><div class="mb-3 flex gap-1 rounded-xl bg-gray-100 p-1 dark:bg-gray-800"><button class="flex-1 cursor-pointer rounded-lg py-2 text-sm font-medium transition-all bg-white text-gray-900 shadow-sm dark:bg-gray-700 dark:text-white">Fiat</button><button class="flex-1 cursor-pointer rounded-lg py-2 text-sm font-medium transition-all text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Stablecoin</button><button class="flex-1 cursor-pointer rounded-lg py-2 text-sm font-medium transition-all text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">BTC</button></div><div class="no-scrollbar flex-1 overflow-y-auto"><div class="space-y-0.5" style="opacity:0;transform:translateY(8px)"><div class="flex items-center justify-between rounded-lg px-3 py-2.5"><div class="flex items-center gap-3"><div class="flex h-8 w-8 shrink-0 items-center justify-center text-xl">🇪🇺</div><div><p class="text-sm font-semibold text-gray-900 dark:text-white">EUR</p><p class="text-xs text-gray-400 dark:text-gray-400">Euro</p></div></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">Same-day</span></div><div class="flex items-center justify-between rounded-lg px-3 py-2.5"><div class="flex items-center gap-3"><div class="flex h-8 w-8 shrink-0 items-center justify-center text-xl">🇺🇸</div><div><p class="text-sm font-semibold text-gray-900 dark:text-white">USD</p><p class="text-xs text-gray-400 dark:text-gray-400">US Dollar</p></div></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">T+1</span></div><div class="flex items-center justify-between rounded-lg px-3 py-2.5"><div class="flex items-center gap-3"><div class="flex h-8 w-8 shrink-0 items-center justify-center text-xl">🇬🇧</div><div><p class="text-sm font-semibold text-gray-900 dark:text-white">GBP</p><p class="text-xs text-gray-400 dark:text-gray-400">Pound Sterling</p></div></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">T+1</span></div><div class="flex items-center justify-between rounded-lg px-3 py-2.5"><div class="flex items-center gap-3"><div class="flex h-8 w-8 shrink-0 items-center justify-center text-xl">🇨🇭</div><div><p class="text-sm font-semibold text-gray-900 dark:text-white">CHF</p><p class="text-xs text-gray-400 dark:text-gray-400">Swiss Franc</p></div></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">T+1</span></div><div class="flex items-center justify-between rounded-lg px-3 py-2.5"><div class="flex items-center gap-3"><div class="flex h-8 w-8 shrink-0 items-center justify-center text-xl">🇲🇽</div><div><p class="text-sm font-semibold text-gray-900 dark:text-white">MXN</p><p class="text-xs text-gray-400 dark:text-gray-400">Mexican Peso</p></div></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">T+1</span></div></div></div></div></div></div><div class="mt-20 border-t border-gray-300 pt-12 dark:border-gray-800"><h2 class="text-md mb-3 flex flex-col font-semibold text-gray-500 dark:text-gray-300">*Or in minutes</h2><div class="relative"><div class="pointer-events-none absolute top-0 left-0 z-10 h-full w-2 bg-linear-to-r from-primary-50 to-transparent dark:from-gray-950"></div><div class="pointer-events-none absolute top-0 right-0 z-10 h-full w-8 bg-linear-to-l from-primary-50 to-transparent dark:from-gray-950"></div><div class="overflow-hidden px-2"><div class="flex gap-3"><a target="_blank" rel="noopener noreferrer" class="flex w-40 shrink-0" data-index="0" href="https://www.circle.com/usdc"><div style="transform:translateX(0px);transition:transform 300ms ease-out;will-change:auto"><div class="relative flex h-20 w-40 items-center justify-center overflow-hidden rounded-2xl shadow-sm" style="clip-path:inset(0 round 1rem);transition:clip-path 300ms ease-out, box-shadow 300ms ease-out;will-change:auto">